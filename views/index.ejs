
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home page</title>
    <link
  href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
  rel="stylesheet">

<link rel="stylesheet" href="/style.css">
</head>
<body>
<%- include("includes/header") %>    
<div class="container">
    <% for(post of posts){ %>

        <div class="post">
            <p>Id : <%= post.id %></p>
            <h3>username : @ <%= post.username %></h3>
            <h4>About : <%= post.content %></h4>

            <p>
                <img src="<%= post.Image %>" alt="Post Image" width="200">
            </p>

            <div class="btn-container">
                <a href="/posts/<%= post.id %>" class="btn my-btn"> See in Detail</a>

                <a href="/posts/<%= post.id %>/edit" class="btn my-btn">
                    Edit Post
                </a>

                <form
                    class="delete-form"
                    action="/posts/<%= post.id %>?_method=DELETE"
                    method="POST">

                    <button class="btn my-btn">
                        Delete Post
                    </button>

                </form>
            </div>

        </div>   <!-- THIS WAS MISSING -->

    <% } %>
</div>
<div class="cr-po">
  <button class="btn my-btn"><a href="http://localhost:8080/posts/new">Create New Post</a></button>
</div>
 <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
